    mkdir -p "$GOLDEN_DIR"

    local log_file="$OUTPUT_ROOT/logs/golden_preproc.log"
    local start_time=$SECONDS

    echo "Command:"
    echo "  $BINARY -u $DWI --epi off --drift off --denoising for_reg \\"
    echo "    --correction_mode off --niter 0 --s2v 0 --repol 0 \\"
    echo "    --temp_folder $GOLDEN_DIR"
    echo ""

    set +e
    run_binary -u "$DWI" --epi off --drift off --denoising for_reg \
        --correction_mode off --niter 0 --s2v 0 --repol 0 \
        --temp_folder "$GOLDEN_DIR" \
        2>&1 | tee "$log_file"
    local exit_code=$?
    set -e

    local elapsed=$(( SECONDS - start_time ))
    echo ""
    echo "Golden preprocessing: exit_code=$exit_code, elapsed=$(format_time $elapsed)"

    if [[ $exit_code -ne 0 ]]; then
        echo "ERROR: Golden preprocessing failed. Cannot continue."
        exit 1
    fi

    # Verify _proc files were created
    local proc_dir
    proc_dir="$(find_golden_proc_dir "$GOLDEN_DIR")"
    if [[ -z "$proc_dir" ]]; then
        echo "ERROR: Golden preprocessing completed but no *_proc.nii found."
        echo "Contents of $GOLDEN_DIR:"
        find "$GOLDEN_DIR" -type f | head -20
        exit 1
    fi

    echo "Golden _proc files in: $proc_dir"
    printf "golden_preproc\t%d\t%d\n" "$exit_code" "$elapsed" >> "$TIMING_FILE"
}

# Only run golden preproc if _proc files don't already exist
GOLDEN_PROC_DIR="$(find_golden_proc_dir "$GOLDEN_DIR")"
if [[ -z "$GOLDEN_PROC_DIR" ]]; then
    run_golden_preproc
    GOLDEN_PROC_DIR="$(find_golden_proc_dir "$GOLDEN_DIR")"
else
    echo ""
    echo "Golden preprocessing already done: $GOLDEN_PROC_DIR"
fi

if [[ -z "$GOLDEN_PROC_DIR" ]]; then
    echo "ERROR: Cannot locate golden _proc files. Aborting."
    exit 1
fi

# ─── Single Test Runner ───────────────────────────────────────────────────
# This function runs one test. It is called directly in sequential mode
# or exported and invoked by GNU parallel.

run_single_test() {
    # Source test definitions (arrays can't be exported to parallel subprocesses)
    if [[ -n "${TEST_DEFS_FILE:-}" && -f "$TEST_DEFS_FILE" ]]; then
        source "$TEST_DEFS_FILE"
    fi
    local test_num="$1"
    local idx=$((test_num - 1))
    local name="${TEST_NAMES[$idx]}"
    local desc="${TEST_DESCS[$idx]}"
    local flags="${TEST_FLAGS[$idx]}"

    local working_dir="$OUTPUT_ROOT/working_${name}"
    local output_dir="$OUTPUT_ROOT/${name}"
    local output_file="$output_dir/${SESSION_ID}_${name}.nii"
    local log_file="$OUTPUT_ROOT/logs/${name}.log"

    echo ""
    echo "────────────────────────────────────────────────────────────────"
    echo "Test $test_num: $name"
    echo "  $desc"
    echo "  Flags: $flags"
    echo "  Working dir: $working_dir"
    echo "  Output dir:  $output_dir"
    echo "────────────────────────────────────────────────────────────────"

    mkdir -p "$working_dir"
    mkdir -p "$output_dir"

    # Prepare: copy golden _proc files into working dir
    prepare_test_folder "$working_dir" "$GOLDEN_PROC_DIR"

    # Build and display the command
    echo ""
    echo "Command:"
    echo "  $BINARY -u $DWI $COMMON $flags --temp_folder $working_dir -o $output_file"
    echo ""

    # Run the test
    local start_time=$SECONDS
    set +e
    run_binary -u "$DWI" $COMMON $flags --temp_folder "$working_dir" -o "$output_file" \
        2>&1 | tee "$log_file"
    local exit_code=$?
    set -e

    local elapsed=$(( SECONDS - start_time ))
    local elapsed_str
    elapsed_str="$(format_time $elapsed)"

    # Check outputs
    local output_status="OK"
    if [[ $exit_code -ne 0 ]]; then
        output_status="FAIL (exit $exit_code)"
    else
        if ! check_outputs "$working_dir" "$output_dir" "$flags"; then
            output_status="WARN (missing outputs)"
        fi
    fi

    # Record to timing file (atomic append)
    printf "%s\t%d\t%d\n" "$name" "$exit_code" "$elapsed" >> "$TIMING_FILE"

    echo ""
    echo "Test $test_num ($name): $output_status — $elapsed_str"

    return $exit_code
}

# Write test definitions to a temp file so GNU parallel subprocesses can source them
# (Bash arrays cannot be exported to subprocesses)
TEST_DEFS_FILE="$(mktemp "${OUTPUT_ROOT}/.test_defs.XXXXXX")"
{
    declare -p TEST_NAMES
    declare -p TEST_DESCS
    declare -p TEST_FLAGS
    declare -p NUM_TESTS
    declare -p DOCKER_VOLUMES
} > "$TEST_DEFS_FILE"
export TEST_DEFS_FILE

# Export everything needed by GNU parallel subprocesses
export -f run_single_test prepare_test_folder check_outputs format_time find_golden_proc_dir run_binary
export OUTPUT_ROOT SESSION_ID GOLDEN_PROC_DIR BINARY DWI COMMON TIMING_FILE
export DOCKER_IMAGE DOCKER_GPU DOCKER_CPUS

# ─── Batch Execution ──────────────────────────────────────────────────────

run_batch() {
    local batch_name="$1"
    shift
    local test_nums=("$@")
    local n_parallel=${#test_nums[@]}

    echo ""
    echo "================================================================"
    echo "Batch: $batch_name (${#test_nums[@]} tests, j${n_parallel})"
    echo "Tests: ${test_nums[*]}"
    echo "================================================================"

    if [[ $n_parallel -eq 1 ]]; then
        # Single test — run directly at full cores
        run_single_test "${test_nums[0]}"
        return $?
    fi

    set_cores_per_process "$n_parallel"

    if [[ $HAS_PARALLEL -eq 1 ]]; then
        set +e
        printf '%s\n' "${test_nums[@]}" | \
            parallel -j"$n_parallel" --line-buffer --halt never \
                run_single_test {}
        local batch_exit=$?
        set -e
    else
        # Sequential fallback
        local batch_exit=0
        for t in "${test_nums[@]}"; do
            set +e
            run_single_test "$t"
            local rc=$?
            set -e
            if [[ $rc -ne 0 ]]; then
                batch_exit=$rc
            fi
        done
    fi

    restore_cores

    return $batch_exit
}

# ─── Main: Run Batches ────────────────────────────────────────────────────

echo ""
echo "================================================================"
echo "Running ${#TESTS_TO_RUN[@]} test(s): ${TESTS_TO_RUN[*]}"
echo "Output root: $OUTPUT_ROOT"
echo "Session ID:  $SESSION_ID"
echo "Parallel:    $(if [[ $HAS_PARALLEL -eq 1 ]]; then echo "GNU parallel available"; else echo "sequential (parallel not found)"; fi)"
echo "================================================================"

# Build a lookup set for quick membership checks
declare -A TESTS_SELECTED
for t in "${TESTS_TO_RUN[@]}"; do
    TESTS_SELECTED[$t]=1
done

# Track results across all batches
declare -A RESULTS
declare -A ELAPSED_TIMES

for batch_def in "${BATCHES[@]}"; do
    IFS=':' read -r batch_name batch_j batch_tests <<< "$batch_def"
    read -ra all_batch_tests <<< "$batch_tests"

    # Filter to only selected tests
    selected_in_batch=()
    for t in "${all_batch_tests[@]}"; do
        if [[ -n "${TESTS_SELECTED[$t]:-}" ]]; then
            selected_in_batch+=("$t")
        fi
    done

    # Skip empty batches
    if [[ ${#selected_in_batch[@]} -eq 0 ]]; then
        continue
    fi

    batch_start=$SECONDS
    set +e
    run_batch "$batch_name" "${selected_in_batch[@]}"
    set -e
    batch_elapsed=$((SECONDS - batch_start))

    echo ""
    echo "Batch $batch_name completed in $(format_time $batch_elapsed)"
done

# ─── Collect Results from Timing File ─────────────────────────────────────

# Re-read timing file to populate RESULTS and ELAPSED_TIMES
while IFS=$'\t' read -r tname texit telapsed; do
    [[ "$tname" == "test_name" ]] && continue
    [[ "$tname" == "golden_preproc" ]] && continue
    for test_num in "${TESTS_TO_RUN[@]}"; do
        idx=$((test_num - 1))
        if [[ "${TEST_NAMES[$idx]}" == "$tname" ]]; then
            if [[ "$texit" -eq 0 ]]; then
                RESULTS[$test_num]="OK"
            else
                RESULTS[$test_num]="FAIL (exit $texit)"
            fi
            ELAPSED_TIMES[$test_num]="$telapsed"
        fi
    done
done < "$TIMING_FILE"

