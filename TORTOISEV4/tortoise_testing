# ─── Parse Test Range ──────────────────────────────────────────────────────

parse_test_range() {
    local range="$1"
    local max="$2"
    local result=()

    if [[ "$range" == "all" ]]; then
        for ((i=1; i<=max; i++)); do
            result+=("$i")
        done
    else
        # Split on commas
        IFS=',' read -ra parts <<< "$range"
        for part in "${parts[@]}"; do
            part="$(echo "$part" | tr -d ' ')"
            if [[ "$part" =~ ^([0-9]+)-([0-9]+)$ ]]; then
                local start="${BASH_REMATCH[1]}"
                local end="${BASH_REMATCH[2]}"
                for ((i=start; i<=end && i<=max; i++)); do
                    result+=("$i")
                done
            elif [[ "$part" =~ ^[0-9]+$ ]]; then
                if [[ "$part" -ge 1 && "$part" -le "$max" ]]; then
                    result+=("$part")
                fi
            else
                echo "Error: Invalid test range component: '$part'"
                exit 1
            fi
        done
    fi

    echo "${result[@]}"
}

TESTS_TO_RUN=($(parse_test_range "$TEST_RANGE" "$NUM_TESTS"))

