# ─── Core Control ──────────────────────────────────────────────────────────

RESERVED_CORES=${RESERVED_CORES:-0}
DOCKER_CPUS=""

if [[ -n "$DOCKER_IMAGE" ]]; then
    # Docker mode: core control via --cpus flag (image has PercentOfCpuCoresToUse=1.0)
    ORIGINAL_SETTINGS=""
    trap 'rm -f "${TEST_DEFS_FILE:-}"' EXIT
    echo "Settings:  Docker --cpus (image handles PercentOfCpuCoresToUse internally)"
else
    # Local mode: core control via settings JSON
    SETTINGS_JSON="${SCRIPT_DIR}/../settings/system_settings/default_system_settings.json"
    if [[ ! -f "$SETTINGS_JSON" ]]; then
        SETTINGS_JSON="${SCRIPT_DIR}/settings/system_settings/default_system_settings.json"
    fi

    if [[ -f "$SETTINGS_JSON" ]]; then
        SETTINGS_JSON="$(realpath "$SETTINGS_JSON")"
        ORIGINAL_SETTINGS="$(cat "$SETTINGS_JSON")"
        trap 'echo "$ORIGINAL_SETTINGS" > "$SETTINGS_JSON"; echo "[cores] Restored original settings"; rm -f "${TEST_DEFS_FILE:-}"' EXIT
        echo "Settings:  $SETTINGS_JSON"
    else
        ORIGINAL_SETTINGS=""
        echo "WARNING: default_system_settings.json not found — skipping core control"
    fi
fi

set_cores_per_process() {
    local n_parallel="$1"
    local total_cores
    total_cores=$(nproc)
    local usable_cores=$((total_cores - RESERVED_CORES))
    if [[ $usable_cores -lt $n_parallel ]]; then
        usable_cores=$n_parallel
    fi
    local cores_each=$((usable_cores / n_parallel))

    if [[ -n "$DOCKER_IMAGE" ]]; then
        DOCKER_CPUS="$cores_each"
        export DOCKER_CPUS
        echo "  [cores] Docker --cpus=$DOCKER_CPUS ($total_cores total, $RESERVED_CORES reserved)"
    else
        if [[ -z "$ORIGINAL_SETTINGS" ]]; then
            return
        fi
        local perc
        perc=$(printf '%.2f' "$(echo "scale=4; $usable_cores / ($total_cores * $n_parallel)" | bc)")
        cat > "$SETTINGS_JSON" <<JSONEOF
{
    "_comment": "Temporarily reduced for parallel testing ($n_parallel processes, $RESERVED_CORES reserved)",
    "PercentOfCpuCoresToUse": $perc
}
JSONEOF
        echo "  [cores] Set PercentOfCpuCoresToUse=$perc ($total_cores total, $RESERVED_CORES reserved, ~$cores_each per process)"
    fi
}

restore_cores() {
    if [[ -n "$DOCKER_IMAGE" ]]; then
        DOCKER_CPUS=""
    elif [[ -n "$ORIGINAL_SETTINGS" ]]; then
        echo "$ORIGINAL_SETTINGS" > "$SETTINGS_JSON"
    fi
}

# ─── Docker/Local Binary Wrapper ──────────────────────────────────────────

run_binary() {
    if [[ -n "$DOCKER_IMAGE" ]]; then
        docker run --rm \
            "${DOCKER_VOLUMES[@]}" \
            -u "$(id -u):$(id -g)" \
            --workdir "$OUTPUT_ROOT" \
            ${DOCKER_CPUS:+--cpus "$DOCKER_CPUS"} \
            ${DOCKER_GPU:+--gpus all} \
            "$DOCKER_IMAGE" \
            "$BINARY" "$@"
    else
        "$BINARY" "$@"
    fi
}

# ─── Helper Functions ──────────────────────────────────────────────────────

format_time() {
    local secs="$1"
    local mins=$((secs / 60))
    local remainder=$((secs % 60))
    if [[ $mins -gt 60 ]]; then
        local hrs=$((mins / 60))
        mins=$((mins % 60))
        printf "%dh%02dm%02ds" "$hrs" "$mins" "$remainder"
    else
        printf "%dm%02ds" "$mins" "$remainder"
    fi
}

# Find the _proc files in golden_preproc. The pipeline creates a subfolder
# structure under temp_folder; we need to locate the actual _proc files.
find_golden_proc_dir() {
    local golden="$1"
    # The _proc files live inside a subject-specific subfolder under golden_preproc
    local proc_dir
    proc_dir="$(find "$golden" -name "*_proc.nii" -printf '%h\n' 2>/dev/null | head -1)"
    if [[ -z "$proc_dir" ]]; then
        echo ""
        return
    fi
    echo "$proc_dir"
}

prepare_test_folder() {
    local test_dir="$1"
    local golden_proc_dir="$2"

    # If the test dir already has _proc files, skip copy
    if find "$test_dir" -maxdepth 1 -name "*_proc.nii" 2>/dev/null | grep -q .; then
        echo "  [prep] _proc files already present in $test_dir, skipping copy"
        return 0
    fi

    mkdir -p "$test_dir"

    # Copy _proc files, metadata, and noise map directly into test_dir
    for pattern in "*_proc.nii" "*_proc.bmtxt" "*_proc.json" "*_noise.nii"; do
        for f in "${golden_proc_dir}"/$pattern; do
            if [[ -f "$f" ]]; then
                cp "$f" "$test_dir/"
            fi
        done
    done

    # Copy logs directory if it exists (pipeline checks for it)
    if [[ -d "${golden_proc_dir}/logs" ]]; then
        cp -r "${golden_proc_dir}/logs" "$test_dir/"
    fi

    echo "  [prep] Copied golden _proc files to $test_dir"
}

check_outputs() {
    local working_dir="$1"
    local output_dir="$2"
    local flags="$3"
    local status=0

    # moteddy output — check working dir for intermediates
    if ! find "$working_dir" -name "*_moteddy.nii" 2>/dev/null | grep -q .; then
        echo "  [MISSING] *_moteddy.nii in working dir"
        status=1
    fi
    if ! find "$working_dir" -name "*_moteddy_transformations.txt" 2>/dev/null | grep -q .; then
        echo "  [MISSING] *_moteddy_transformations.txt in working dir"
        status=1
    fi

    # S2V transforms (when --s2v 1)
    if echo "$flags" | grep -q -- "--s2v 1"; then
        if ! find "$working_dir" -name "*_s2v_transformations.txt" 2>/dev/null | grep -q .; then
            echo "  [MISSING] *_s2v_transformations.txt (expected with --s2v 1)"
            status=1
        fi
    fi

    # Outlier map (when --repol 1)
    if echo "$flags" | grep -q -- "--repol 1"; then
        if ! find "$working_dir" -name "*_native_inclusion.nii" 2>/dev/null | grep -q .; then
            echo "  [MISSING] *_native_inclusion.nii (expected with --repol 1)"
            status=1
        fi
    fi

    # b0 quad reference
    if ! find "$working_dir" -name "blip_up_b0_quad.nii" 2>/dev/null | grep -q .; then
        echo "  [NOTE] blip_up_b0_quad.nii not found (may be in subfolder)"
    fi

    # Check output dir for final output
    if [[ -d "$output_dir" ]]; then
        if ! find "$output_dir" -name "*.nii" 2>/dev/null | grep -q .; then
            echo "  [NOTE] No .nii files in output dir yet"
        fi
    fi

    return $status
}

# ─── Phase 0: Golden Preprocessing ────────────────────────────────────────

GOLDEN_DIR="$OUTPUT_ROOT/golden_preproc"

