#!/bin/bash
set -euo pipefail

###############################################################################
# tortoise_testing — DIFFPREP integration test battery
#
# Exercises the TORTOISE DIFFPREP motion/eddy/S2V/outlier-replacement pipeline
# on real multi-shell DWI data. Each test adds one CLI feature so the user can
# isolate each addition's effect. EPI distortion correction is disabled
# throughout (--epi off).
#
# Tests run in parallel within each phase via GNU `parallel`. Core allocation
# is managed automatically via default_system_settings.json.
#
# Usage:
#   ./tortoise_testing <session_dwi_dir> [output_root] [test_range]
#
# Arguments:
#   session_dwi_dir   BIDS dwi/ directory containing .nii.gz, .bval, .bvec, .json
#   output_root       Where results are saved (default: ./tortoise_test_results)
#   test_range        "1-3", "8", "all" (default: "all")
#
# Examples:
#   ./tortoise_testing testing_data/sub-PretestSubject4triple/ses-still/dwi
#   ./tortoise_testing testing_data/sub-PretestSubject4triple/ses-3yomotion/dwi ./results_motion
#   ./tortoise_testing testing_data/sub-PretestSubject4triple/ses-still/dwi ./results_still "1-3"
###############################################################################

# ─── Usage / Help ────────────────────────────────────────────────────────────

usage() {
    cat <<'USAGE'
Usage: tortoise_testing [options] <session_dwi_dir> [output_root] [test_range]

Options:
  --docker IMAGE        Run TORTOISE inside a Docker container using IMAGE
  --docker-mount PATH   Mount root for the container (default: auto-detect from paths)
  --docker-gpu          Use GPU binary (TORTOISEProcess_cuda) and pass --gpus all

Arguments:
  session_dwi_dir   BIDS dwi/ directory containing .nii.gz (or .nii), .bval, .bvec, .json
  output_root       Where results are saved (default: ./tortoise_test_results)
  test_range        Which tests to run: "all" (default), "1-3", "4", "8-12", etc.

Test Battery (23 tests, 6 phases):
  Phase 1 — Baseline eddy models (niter=0, single-pass register-to-b0) [Batch 1, j2]
    01  p1_rigid_only           Rigid 6-DOF motion only
    02  p1_quadratic_eddy       14-DOF motion + quadratic eddy (default model)

  Phase 2 — Iterative refinement + feature activation (niter=4) [Batch 2, j4]
    03  p2_quad_iterative       MAPMRI synth-target registration (1 epoch)
    04  p2_quad_repol           + outlier detection/replacement
    05  p2_quad_s2v             + slice-to-volume correction
    06  p2_quad_s2v_repol       Full EDDY-equivalent baseline

  Phase 3a — Isolated S2V knobs (test 06 + one flag each) [Batch 3, j4]
    07  p3a_iso_smoothing       Coarse-to-fine S2V smoothing schedule
    08  p3a_iso_subiters        Multiple S2V passes per epoch
    09  p3a_iso_warm_start      Carry forward transforms across epochs
    10  p3a_iso_temporal_reg    Temporal regularization across MB groups

  Phase 3b — Cumulative S2V stacking (on test 06) [Batch 4, j5]
    11  p3b_cum_smoothing       Smoothing
    12  p3b_cum_subiters        + sub-iterations
    13  p3b_cum_warm_start      + warm start
    14  p3b_cum_temporal_reg    + temporal reg (fully-tuned)
    15  p3b_cum_convergence     Extended niter=5 + convergence threshold

  Phase 4 — Motion correction flags [Batch 5, j6]
    16  p4_lmc_baseline         Large motion correction (test 06 base)
    17  p4_s2v_ms_baseline      S2V multistart (test 06 base)
    18  p4_lmc_ms_baseline      LMC + S2V multistart (test 06 base)
    19  p4_lmc_tuned            Large motion correction (test 14 tuned)
    20  p4_s2v_ms_tuned         S2V multistart (test 14 tuned)
    21  p4_lmc_ms_tuned         LMC + S2V multistart (test 14 tuned)

  Phase 5 — Advanced [Batch 6, j2]
    22  p5_mapmri_schedule      Progressive MAPMRI complexity (degree 2->4->4->6)
    23  p5_aggressive_repol     Aggressive outlier flagging

USAGE
    exit 0
}

# ─── Argument Parsing ────────────────────────────────────────────────────────

DOCKER_IMAGE=""
DOCKER_MOUNT=""
DOCKER_GPU=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --docker)       [[ $# -ge 2 ]] || { echo "Error: --docker requires an image name"; exit 1; }
                        DOCKER_IMAGE="$2"; shift 2 ;;
        --docker-mount) [[ $# -ge 2 ]] || { echo "Error: --docker-mount requires a path"; exit 1; }
                        DOCKER_MOUNT="$2"; shift 2 ;;
        --docker-gpu)   DOCKER_GPU=1; shift ;;
        --help|-h)      usage ;;
        -*)             echo "Unknown flag: $1"; usage ;;
        *)              break ;;  # positional args start
    esac
done

if [[ $# -lt 1 ]]; then
    echo "Error: session_dwi_dir is required."
    usage
fi

DWI_DIR="$(realpath "$1")"
OUTPUT_ROOT="$(realpath "${2:-./tortoise_test_results}")"
TEST_RANGE="${3:-all}"

# ─── Docker Volume Mounts ──────────────────────────────────────────────────

DOCKER_VOLUMES=()
if [[ -n "$DOCKER_IMAGE" ]]; then
    if [[ -n "$DOCKER_MOUNT" ]]; then
        DOCKER_VOLUMES=(-v "$DOCKER_MOUNT:$DOCKER_MOUNT")
    else
        DOCKER_VOLUMES=(-v "$DWI_DIR:$DWI_DIR" -v "$OUTPUT_ROOT:$OUTPUT_ROOT")
    fi
fi

# ─── Session ID Extraction ──────────────────────────────────────────────────

SESSION_ID=""
IFS='/' read -ra path_parts <<< "$DWI_DIR"
for part in "${path_parts[@]}"; do
    [[ "$part" == ses-* ]] && SESSION_ID="$part"
done
[[ -z "$SESSION_ID" ]] && SESSION_ID="unknown_session"

# ─── Locate the DWI file and sidecars ──────────────────────────────────────

DWI=""
for ext in .nii.gz .nii; do
    candidate="$(find "$DWI_DIR" -maxdepth 1 -name "*${ext}" -not -name "*._*" | head -1)"
    if [[ -n "$candidate" ]]; then
        DWI="$candidate"
        break
    fi
done

if [[ -z "$DWI" ]]; then
    echo "Error: No .nii.gz or .nii file found in $DWI_DIR"
    exit 1
fi

# Derive sidecar paths from the DWI filename
DWI_BASE="${DWI%.nii.gz}"
DWI_BASE="${DWI_BASE%.nii}"
BVAL="${DWI_BASE}.bval"
BVEC="${DWI_BASE}.bvec"
JSON="${DWI_BASE}.json"

echo "DWI file:  $DWI"

missing_sidecars=0
for f in "$BVAL" "$BVEC" "$JSON"; do
    if [[ ! -f "$f" ]]; then
        echo "Error: Missing sidecar: $f"
        missing_sidecars=1
    fi
done
if [[ $missing_sidecars -eq 1 ]]; then
    exit 1
fi

echo "Sidecars:  .bval .bvec .json — OK"
echo "Session:   $SESSION_ID"

# ─── Input Validation Warnings ─────────────────────────────────────────────

# Check for SliceTiming in JSON
if ! grep -q '"SliceTiming"' "$JSON" 2>/dev/null; then
    echo "WARNING: JSON missing SliceTiming — S2V tests (05-23) need it for meaningful results."
    echo "         Also check for MultibandAccelerationFactor."
fi

# Check volume count
NVOLS=$(wc -w < "$BVAL" 2>/dev/null || echo 0)
echo "Volumes:   $NVOLS"
if [[ "$NVOLS" -lt 20 ]]; then
    echo "WARNING: <20 volumes — DIFFPREP will auto-disable s2v and repol (DIFFPREP.cxx:1414)."
fi

# ─── Auto-detect Binary ───────────────────────────────────────────────────

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
BINARY=""

if [[ -n "$DOCKER_IMAGE" ]]; then
    # Docker mode: binary lives inside the container, not on the host
    if [[ -n "$DOCKER_GPU" ]]; then
        BINARY="TORTOISEProcess_cuda"
    else
        BINARY="TORTOISEProcess"
    fi
    echo "Binary:    $BINARY (Docker: $DOCKER_IMAGE)"
    echo "Docker:    mounts: ${DOCKER_VOLUMES[*]}"

    # Preflight: verify image works before committing to a long run
    echo -n "Preflight: "
    set +o pipefail
    preflight_out="$(docker run --rm "$DOCKER_IMAGE" "$BINARY" 2>&1 | head -5)"
    set -o pipefail
    if echo "$preflight_out" | grep -q "COMMAND:"; then
        echo "OK — $DOCKER_IMAGE responds"
    else
        echo "FAILED — cannot run '$BINARY' in image '$DOCKER_IMAGE'"
        echo "Check: docker run --rm $DOCKER_IMAGE $BINARY"
        exit 1
    fi
else
    # Local mode: auto-detect binary from build directories
    for search_dir in "$SCRIPT_DIR" "$SCRIPT_DIR/.."; do
        if [[ -x "${search_dir}/bin/TORTOISEProcess_cuda" ]]; then
            BINARY="$(realpath "${search_dir}/bin/TORTOISEProcess_cuda")"
            echo "Binary:    TORTOISEProcess_cuda (GPU) — $BINARY"
            break
        elif [[ -x "${search_dir}/bin/TORTOISEProcess" ]]; then
            BINARY="$(realpath "${search_dir}/bin/TORTOISEProcess")"
            echo "Binary:    TORTOISEProcess (CPU) — $BINARY"
            break
        fi
    done
    if [[ -z "$BINARY" ]]; then
        echo "Error: Neither TORTOISEProcess_cuda nor TORTOISEProcess found in"
        echo "  ${SCRIPT_DIR}/bin/ or ${SCRIPT_DIR}/../bin/"
        echo "Build first: cd TORTOISEV4 && cmake . && make -j 16"
        exit 1
    fi
fi

# ─── Check for GNU parallel ────────────────────────────────────────────────

if ! command -v parallel &>/dev/null; then
    echo "WARNING: GNU parallel not found. Tests will run sequentially."
    echo "         Install: sudo apt install parallel"
    HAS_PARALLEL=0
else
    HAS_PARALLEL=1
    # Suppress citation notice
    mkdir -p ~/.parallel
    touch ~/.parallel/will-cite 2>/dev/null || true
fi

